@model IEnumerable<Sistema_Actividades_Tlahuac.Models.Alumnos.Alumno>

<div class="container mt-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
        <div>
            <h2 class="fw-bold mb-1" style="color:#5a0f2e;">
                <i class="bi bi-people-fill me-2"></i>
                Mis alumnos
            </h2>
            <p class="text-muted mb-0">
                Consulta y administra los alumnos registrados desde tu cuenta.
            </p>
        </div>

        <a asp-action="Create" class="btn btn-dorado">
            <i class="bi bi-person-plus-fill me-1"></i>
            Registrar alumno
        </a>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body p-3 p-md-4">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-center">
                    <div class="col-12 col-md-10">
                        <input type="text"
                               name="busqueda"
                               value="@ViewBag.Busqueda"
                               class="form-control"
                               placeholder="Buscar por nombre, apellido paterno o materno..." />
                    </div>
                    <div class="col-12 col-md-2 d-grid">
                        <button type="submit" class="btn btn-outline-secondary">
                            <i class="bi bi-search me-1"></i> Buscar
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            @TempData["Info"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                var esPropio = item.Parentesco != null && item.Parentesco.Nombre == "PROPIO";
                var estaActivo = item.Estado == Sistema_Actividades_Tlahuac.Models.Enums.EstadoRegistro.Activo;

                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card h-100 shadow-sm border-0 alumno-card">
                        <div class="card-header text-white"
                             style="background: linear-gradient(90deg, #5a0f2e, #a51c30);">
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div class="fw-semibold text-truncate">
                                    <i class="bi bi-person-badge-fill me-1"></i>
                                    @item.NombreCompleto
                                </div>

                                @if (estaActivo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @if (esPropio)
                                {
                                    <span class="badge rounded-pill bg-primary">
                                        <i class="bi bi-person-check me-1"></i> Propio
                                    </span>
                                }
                                else
                                {
                                    <span class="badge rounded-pill bg-warning text-dark">
                                        <i class="bi bi-people me-1"></i> Dependiente
                                    </span>
                                }

                                <span class="badge rounded-pill bg-light text-dark border">
                                    @(item.Parentesco?.Nombre ?? "Sin parentesco")
                                </span>
                            </div>

                            <div class="info-block mb-3">
                                <small class="text-muted d-block">Fecha de nacimiento</small>
                                <div class="fw-semibold">
                                    @item.FechaNacimiento.ToString("dd/MM/yyyy")
                                </div>
                            </div>

                            <div class="info-block mb-3">
                                <small class="text-muted d-block">CURP</small>
                                <div class="fw-semibold">
                                    @(string.IsNullOrWhiteSpace(item.Curp) ? "No registrada" : item.Curp)
                                </div>
                            </div>

                            <div class="info-block">
                                <small class="text-muted d-block">Teléfono de contacto</small>
                                <div class="fw-semibold">
                                    @(string.IsNullOrWhiteSpace(item.TelefonoContacto) ? "No registrado" : item.TelefonoContacto)
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white border-0 p-3">
                            <div class="d-grid gap-2">
                                <div class="row g-2">
                                    <div class="col-12 col-sm-6">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-secondary btn-sm w-100">
                                            <i class="bi bi-eye-fill me-1"></i> Detalles
                                        </a>
                                    </div>
                                    <div class="col-12 col-sm-6">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-outline-primary btn-sm w-100">
                                            <i class="bi bi-pencil-square me-1"></i> Editar
                                        </a>
                                    </div>
                                </div>

                                @if (estaActivo)
                                {
                                    <form asp-action="Desactivar" method="post" class="d-grid">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-danger btn-sm"
                                                onclick="return confirm('¿Deseas desactivar este alumno?');">
                                            <i class="bi bi-slash-circle me-1"></i> Desactivar
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="Activar" method="post" class="d-grid">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit"
                                                class="btn btn-outline-success btn-sm"
                                                onclick="return confirm('¿Deseas activar este alumno?');">
                                            <i class="bi bi-check-circle me-1"></i> Activar
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="bi bi-person-x display-5 text-muted"></i>
                <h5 class="mt-3">No tienes alumnos registrados</h5>
                <p class="text-muted mb-4">
                    Puedes registrar tu primer alumno para comenzar a inscribirlo en actividades.
                </p>
                <a asp-action="Create" class="btn btn-dorado">
                    <i class="bi bi-person-plus-fill me-1"></i>
                    Registrar alumno
                </a>
            </div>
        </div>
    }

</div>

<style>
    .alumno-card {
        transition: transform .2s ease, box-shadow .2s ease;
    }

        .alumno-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 .75rem 1.5rem rgba(0,0,0,.08) !important;
        }

    .info-block {
        padding: .85rem 1rem;
        border-radius: .75rem;
        background: #f8f9fa;
    }
</style>