@model Sistema_Actividades_Tlahuac.Models.Alumnos.Alumno

@{
    ViewData["Title"] = "Detalles del alumno";
}

<partial name="_Header_Vistas" />

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="fw-bold" style="color:#5a0f2e;">
            <i class="bi bi-card-list me-2"></i>
            Detalles del alumno
        </h2>

        <p class="text-muted mb-0">
            Consulta la información registrada del alumno.
        </p>
    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header text-white"
             style="background: linear-gradient(90deg, #5a0f2e, #a51c30);">

            <h5 class="mb-0">
                Ficha del alumno
            </h5>

        </div>

        <div class="card-body p-4">

            <div class="row g-3">

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">Nombre completo</small>
                        <div class="fw-semibold fs-5">@Model.NombreCompleto</div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">Fecha de nacimiento</small>
                        <div class="fw-semibold">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">CURP</small>
                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(Model.Curp) ? "No registrada" : Model.Curp)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">Teléfono de contacto</small>
                        <div class="fw-semibold">
                            @(string.IsNullOrWhiteSpace(Model.TelefonoContacto) ? "No registrado" : Model.TelefonoContacto)
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">Parentesco</small>
                        <div class="fw-semibold">
                            @(Model.Parentesco?.Nombre ?? "No registrado")
                        </div>
                    </div>
                </div>

                <div class="col-12 col-md-6">
                    <div class="p-3 rounded-3 bg-light h-100">
                        <small class="text-muted d-block">Estado</small>
                        <div class="fw-semibold">
                            @if (Model.Estado == Sistema_Actividades_Tlahuac.Models.Enums.EstadoRegistro.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Inactivo</span>
                            }
                        </div>
                    </div>
                </div>

            </div>

            <div class="mt-4 p-3 rounded-3"
                 style="background-color:#f8f4ea; border-left:4px solid #C9A227;">

                <small class="text-muted d-block">
                    Este registro pertenece a tu cuenta y solo tú puedes consultarlo o modificarlo.
                </small>

            </div>

            <div class="mt-4 d-flex justify-content-end gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dorado">
                    <i class="bi bi-pencil-square me-1"></i>
                    Editar
                </a>

                <a asp-action="Index" class="btn btn-light border">
                    <i class="bi bi-arrow-left me-1"></i>
                    Volver
                </a>
            </div>

        </div>

    </div>

</div>