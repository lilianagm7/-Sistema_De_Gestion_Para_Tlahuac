@model Sistema_Actividades_Tlahuac.Models.ViewModels.Alumnos.AlumnoCreateViewModel

@{

    bool esPropio = ViewBag.EsPropio == null ? true : (bool)ViewBag.EsPropio;
}

<div class="container mt-4">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3 mb-4">

        <div>
            <h2 class="fw-bold mb-1" style="color:#5a0f2e;">
                <i class="bi bi-person-plus-fill me-2"></i>
                Registrar alumno
            </h2>

            <p class="text-muted mb-0">
                Puedes registrarte a ti mismo o registrar a un dependiente desde tu cuenta.
            </p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-house"></i>
                <span class="d-none d-md-inline"> Inicio</span>
            </a>

            <a asp-action="Index"
               class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i>
            </a>
        </div>

    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header text-white"
             style="background: linear-gradient(90deg, #5a0f2e, #a51c30);">
            <h5 class="mb-0">Información del alumno</h5>
        </div>

        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                @Html.HiddenFor(m => m.Estado)

                <div class="mb-4">
                    <label class="form-label fw-semibold d-block">¿El alumno eres tú?</label>

                    <div class="form-check form-check-inline">
                        <input class="form-check-input"
                               type="radio"
                               name="esPropio"
                               id="esPropioSi"
                               value="true"
                               @(esPropio ? "checked" : "") />
                        <label class="form-check-label" for="esPropioSi">
                            Sí, soy yo
                        </label>
                    </div>

                    <div class="form-check form-check-inline">
                        <input class="form-check-input"
                               type="radio"
                               name="esPropio"
                               id="esPropioNo"
                               value="false"
                               @(!esPropio ? "checked" : "") />
                        <label class="form-check-label" for="esPropioNo">
                            No, es otra persona
                        </label>
                    </div>
                    

                    <div class="form-text">
                        Si eliges “Sí”, el sistema usará tus datos de cuenta.
                    </div>
                    
                    <div class="mt-4 p-3 rounded-3"
                               style="background-color:#f8f4ea; border-left:4px solid #C9A227;">
                        <small class="text-muted d-block">
                            Si el alumno no eres tú, selecciona el parentesco correspondiente.
                        </small>
                    </div>
                </div>

                

                <div id="contenedorParentesco" class="mb-4" style="display:none;">
                    <label asp-for="ParentescoId" class="form-label fw-semibold"></label>
                    <select asp-for="ParentescoId" asp-items="Model.Parentescos" class="form-select">
                        <option value="">-- Selecciona un parentesco --</option>
                    </select>
                    <span asp-validation-for="ParentescoId" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-4">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control text-uppercase campo-propio" autocomplete="off" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label asp-for="ApellidoPaterno" class="form-label fw-semibold"></label>
                        <input asp-for="ApellidoPaterno"
                               class="form-control text-uppercase campo-propio"
                               autocomplete="off" />
                        <span asp-validation-for="ApellidoPaterno" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-4">
                        <label asp-for="ApellidoMaterno" class="form-label fw-semibold"></label>
                        <input asp-for="ApellidoMaterno"
                               class="form-control text-uppercase campo-propio"
                               autocomplete="off" />
                        <span asp-validation-for="ApellidoMaterno" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="FechaNacimiento" class="form-label fw-semibold"></label>
                        <input asp-for="FechaNacimiento" type="date" class="form-control" />
                        <span asp-validation-for="FechaNacimiento" class="text-danger"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="TelefonoContacto" class="form-label fw-semibold"></label>
                        <input asp-for="TelefonoContacto" class="form-control" autocomplete="off" />
                        <span asp-validation-for="TelefonoContacto" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Curp" class="form-label fw-semibold"></label>
                        <input asp-for="Curp"
                               class="form-control text-uppercase"
                               autocomplete="off" />
                        <span asp-validation-for="Curp" class="text-danger"></span>
                    </div>
                </div>


                <div class="mt-4 d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-light border">
                        <i class="bi bi-arrow-left me-1"></i>
                        Cancelar
                    </a>

                    <button type="submit" class="btn btn-dorado">
                        <i class="bi bi-save me-1"></i>
                        Guardar
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const radioPropioSi = document.getElementById('esPropioSi');
        const radioPropioNo = document.getElementById('esPropioNo');
        const contenedorParentesco = document.getElementById('contenedorParentesco');
        const camposPropio = document.querySelectorAll('.campo-propio');

        function toggleFormulario() {
            const esPropio = radioPropioSi.checked;

            contenedorParentesco.style.display = esPropio ? 'none' : 'block';

            camposPropio.forEach(campo => {
                campo.readOnly = esPropio;
                campo.classList.toggle('bg-light', esPropio);
            });
        }

        radioPropioSi.addEventListener('change', toggleFormulario);
        radioPropioNo.addEventListener('change', toggleFormulario);
        toggleFormulario();
    </script>
}