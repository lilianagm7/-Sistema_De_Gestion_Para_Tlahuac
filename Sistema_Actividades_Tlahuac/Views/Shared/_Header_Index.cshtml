
<div class="d-flex justify-content-between align-items-center mb-3">

    <h1 class="mb-0">@ViewData["Title"]</h1>

    <div class="d-flex align-items-center gap-2">
        <!-- Botones-->
        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Index" asp-route-mostrarInactivos="false" class="btn btn-secondary">
                <i class="bi bi-check-circle"></i>
            </a>

            <a asp-action="Index" asp-route-mostrarInactivos="true" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i>
            </a>
        }

        <form method="get"
              asp-controller="@ViewContext.RouteData.Values["controller"]"
              asp-action="Index"
              class="d-flex">
            <input type="text"
                   name="buscador"
                   value="@Context.Request.Query["buscador"]"
                   class="form-control form-control-sm"
                   style="width:300px;"
                   placeholder="Buscar..." />

            <button type="submit" class="btn btn-dorado ms-2">
                <i class="bi bi-search"></i>
            </button>
        </form>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-secondary">
            <i class="bi bi-house"></i>
        </a>

        @if (User.IsInRole("Administrador"))
        {
            <a asp-action="Create"
               class="btn btn-dorado">
                <i class="bi bi-plus-lg"></i> Nuevo
            </a>
        }
    </div>
</div>