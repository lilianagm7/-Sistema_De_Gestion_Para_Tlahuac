@model Sistema_Actividades_Tlahuac.Models.Catalogos.Categoria

@{
    ViewData["Title"] = "Desactivar la categoría";
}

@{
    var boton = new
    {
        Id = Model.Id,
        Controller = "Categorias",
        Action = "Delete"
    };
}

<partial name="_Header_Vistas" />

<hr />

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-md-10 col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="text-danger mb-4">
                        ¿Estás seguro de desactivar esta categoría?
                    </h5>

                    <dl class="row mb-0">

                        <dt class="col-12 col-md-4 fw-semibold">
                            @Html.DisplayNameFor(model => model.Nombre)
                        </dt>
                        <dd class="col-12 col-md-8">
                            @Model.Nombre
                        </dd>

                        <dt class="col-12 col-md-4 fw-semibold">
                            @Html.DisplayNameFor(model => model.Descripcion)
                        </dt>
                        <dd class="col-12 col-md-8 text-muted">
                            @Model.Descripcion
                        </dd>

                        <dt class="col-12 col-md-4 fw-semibold">
                            @Html.DisplayNameFor(model => model.Estado)
                        </dt>
                        <dd class="col-12 col-md-8">
                            @if (Model.Estado == Sistema_Actividades_Tlahuac.Models.Enums.EstadoRegistro.Activo)
                            {
                                <span class="badge bg-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Inactivo</span>
                            }
                        </dd>

                    </dl>

                    <div class="mt-4 d-flex justify-content-end">
                        <partial name="_Boton_Desactivar" model="boton" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>