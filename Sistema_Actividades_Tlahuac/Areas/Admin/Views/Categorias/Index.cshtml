@model IEnumerable<Sistema_Actividades_Tlahuac.Models.Catalogos.Categoria>
@using Sistema_Actividades_Tlahuac.Models.Enums;

@{
    ViewData["Title"] = "Categorías";
}

<partial name="_Header_Index" />

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Descripción</th>
                            <th>Estado</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @item.Nombre
                                </td>

                                <td class="text-muted">
                                    @item.Descripcion
                                </td>

                                <td>
                                    @if (item.Estado == EstadoRegistro.Activo)
                                    {
                                        <span class="badge bg-success">Activo</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactivo</span>
                                    }
                                </td>

                                <td class="text-end">
                                    <partial name="_Botones_Tablas" model="item.Id" />
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>