@model Sistema_Actividades_Tlahuac.Models.Catalogos.Lugar

@{
    ViewData["Title"] = "Desactivar el lugar";
}

@{
    var boton = new
    {
        Id = Model.Id,
        Controller = "Lugares",
        Action = "Delete"
    };
}

<partial name="_Header_Vistas" />

<div class="container">

    <div class="row justify-content-center align-items-center min-vh-75">

        <div class="col-12 col-md-10 col-lg-7">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <div class="card-body p-4">

                    <div class="row g-3">

                        <div class="col-12 col-md-6">
                            <strong>Nombre</strong>
                            <div class="text-muted">@Model.Nombre</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <strong>Colonia</strong>
                            <div class="text-muted">@Model.Colonia</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <strong>Sección</strong>
                            <div class="text-muted">@Model.Seccion</div>
                        </div>

                        <div class="col-12 col-md-6">
                            <strong>Estado</strong>
                            <div>
                                @if (Model.Estado == Sistema_Actividades_Tlahuac.Models.Enums.EstadoRegistro.Activo)
                                {
                                    <span class="badge bg-success">Activo</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Inactivo</span>
                                }
                            </div>
                        </div>

                        <div class="col-12">
                            <strong>Dirección</strong>
                            <div class="text-muted">
                                @Model.Direccion
                            </div>
                        </div>

                    </div>
                    <div class="alert alert-warning mt-4 rounded-3">

                        <i class="bi bi-info-circle-fill"></i>

                        Al desactivar este lugar, los eventos relacionados podrían dejar de mostrarse.

                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4">
                        <partial name="_Boton_Desactivar" model="boton" />

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>