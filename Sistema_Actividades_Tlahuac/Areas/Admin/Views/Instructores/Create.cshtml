@model Sistema_Actividades_Tlahuac.Models.Actores.Instructor
@using Sistema_Actividades_Tlahuac.Models.Enums

@{
    ViewData["Title"] = "Crear nuevo instructor";
}

<partial name="_Header_Vistas" />
<hr />

<div class="container">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h4 class="mb-0">Nuevo instructor</h4>
                </div>

                <div class="card-body">
                    <form asp-action="Create" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>

                        <div class="row g-3">

                            <div class="col-md-6">
                                <label asp-for="UserId" class="control-label"></label>
                                <select asp-for="UserId" asp-items="ViewBag.UserId" class="form-control">
                                    <option value="">-- Selecciona un usuario --</option>
                                </select>
                                <span asp-validation-for="UserId" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="RFC" class="control-label"></label>
                                <input asp-for="RFC" class="form-control" />
                                <span asp-validation-for="RFC" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Especialidad" class="control-label"></label>
                                <input asp-for="Especialidad" class="form-control" />
                                <span asp-validation-for="Especialidad" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="NivelAcademico" class="control-label"></label>
                                <select asp-for="NivelAcademico"
                                        asp-items="Html.GetEnumSelectList<GradoAcademico>()"
                                        class="form-control">
                                    <option value="">-- Selecciona un grado --</option>
                                </select>
                                <span asp-validation-for="NivelAcademico" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="TipoContrato" class="control-label"></label>
                                <select asp-for="TipoContrato"
                                        asp-items="Html.GetEnumSelectList<TipoContrato>()"
                                        class="form-control">
                                    <option value="">-- Selecciona un tipo de contrato --</option>
                                </select>
                                <span asp-validation-for="TipoContrato" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Salario" class="control-label"></label>
                                <input asp-for="Salario" class="form-control" />
                                <span asp-validation-for="Salario" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FechaIngreso" class="control-label"></label>
                                <input asp-for="FechaIngreso" type="date" class="form-control" />
                                <span asp-validation-for="FechaIngreso" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="FechaFinContrato" class="control-label"></label>
                                <input asp-for="FechaFinContrato" type="date" class="form-control" />
                                <span asp-validation-for="FechaFinContrato" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Telefono" class="control-label"></label>
                                <input asp-for="Telefono" class="form-control" />
                                <span asp-validation-for="Telefono" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="EmailContacto" class="control-label"></label>
                                <input asp-for="EmailContacto" class="form-control" />
                                <span asp-validation-for="EmailContacto" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Direccion" class="control-label"></label>
                                <input asp-for="Direccion" class="form-control" />
                                <span asp-validation-for="Direccion" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="DescripcionGrado" class="control-label"></label>
                                <input asp-for="DescripcionGrado" class="form-control" />
                                <span asp-validation-for="DescripcionGrado" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="FotoArchivo" class="control-label"></label>
                                <input asp-for="FotoArchivo" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                                <span asp-validation-for="FotoArchivo" class="text-danger"></span>
                                <small class="text-muted">Formatos permitidos: JPG, JPEG, PNG. Tamaño máximo: 2MB.</small>
                            </div>

                        </div>

                        <div class="mt-4 d-flex justify-content-end gap-2">
                            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-dorado">Crear</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}