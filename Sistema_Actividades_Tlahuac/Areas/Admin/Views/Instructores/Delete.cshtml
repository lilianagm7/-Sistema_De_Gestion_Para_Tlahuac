@model Sistema_Actividades_Tlahuac.Models.Actores.Instructor

@{
    ViewData["Title"] = "Desactivar instructor";
}

@{
    var boton = new
    {
        Id = Model.Id,
        Controller = "Instructores",
        Action = "Delete"
    };
}

<partial name="_Header_Vistas" />

<hr />

<div class="container">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-9">

            <div class="card shadow border-0 overflow-hidden">

               

                <div class="card-body p-4">

                    <div class="row align-items-center">

                        <!-- FOTO -->
                        <div class="col-12 col-md-4 text-center mb-4 mb-md-0">

                            <img src="@(string.IsNullOrEmpty(Model.FotoUrl)
                                                                 ? "/images/default-user.png"
                                                                 : Model.FotoUrl)"
                                 class="img-fluid instructor-img" />

                        </div>

                        <!-- INFORMACIÓN -->
                        <div class="col-12 col-md-8">

                            <h3 class="fw-bold mb-1">
                                @Model.Usuario?.UserName
                            </h3>

                            <p class="text-muted mb-4">
                                @Model.Especialidad
                            </p>

                            <div class="row">

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>RFC</strong><br />
                                    @Model.RFC
                                </div>

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>Teléfono</strong><br />
                                    @Model.Telefono
                                </div>

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>Correo</strong><br />
                                    @Model.EmailContacto
                                </div>

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>Nivel académico</strong><br />
                                    @Model.NivelAcademico
                                </div>

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>Contrato</strong><br />
                                    @Model.TipoContrato
                                </div>

                                <div class="col-12 col-md-6 mb-3">
                                    <strong>Salario</strong><br />
                                    @Model.Salario.ToString("C")
                                </div>

                                <div class="col-12 mb-3">
                                    <strong>Dirección</strong><br />
                                    @Model.Direccion
                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="alert alert-warning mt-4 mb-0">

                        <i class="bi bi-exclamation-circle-fill"></i>

                        Esta acción desactivará al instructor del sistema.
                        Podrá reactivarse posteriormente si es necesario.

                    </div>

                    <div class="mt-4 d-flex justify-content-end">
                        <partial name="_Boton_Desactivar" model="boton" />
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>