@model Sistema_Actividades_Tlahuac.Models.Actores.Instructor

@{
    ViewData["Title"] = "Detalles del instructor";
}

<partial name="_Header_Vistas" />

<div class="container mt-4">
    <div class="card border-0 shadow-sm rounded-4">
        <div class="card-body p-4">

            <div class="d-flex align-items-center gap-4 flex-wrap mb-4">
                <img src="@(Model.FotoUrl ?? "/images/default-user.png")"
                     class="rounded-circle border shadow-sm"
                     alt="Fotografía del instructor"
                     style="width:120px; height:120px; object-fit:cover;" />

                <div class="flex-grow-1">
                    <h3 class="fw-bold mb-1">
                        @Model.Usuario?.NombreCompleto
                    </h3>

                    <p class="text-muted mb-1">
                        RFC: @Model.RFC
                    </p>

                    <div class="d-flex align-items-center gap-2 flex-wrap mt-2">
                        <span class="fw-semibold text-muted">Usuario:</span>

                        <span id="correoUsuario" class="text-dark">
                            @Model.Usuario?.Email
                        </span>

                        <button type="button"
                                class="btn btn-sm btn-detalles rounded-circle d-flex align-items-center justify-content-center"
                                style="width:32px; height:32px;"
                                onclick="copiarCorreo()"
                                aria-label="Copiar correo de inicio de sesión">
                            <i class="bi bi-copy"></i>
                        </button>
                    </div>

                    <div class="mt-3">
                        <span class="badge rounded-pill @(Model.Estado == Sistema_Actividades_Tlahuac.Models.Enums.EstadoRegistro.Activo
                                                                                        ? "bg-success-subtle text-success"
                                                                                        : "bg-secondary-subtle text-secondary") px-3 py-2">
                            @Model.Estado
                        </span>
                    </div>
                </div>
            </div>

            <hr />

            <h6 class="text-muted mb-4">Información profesional</h6>

            <div class="row g-4">
                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Especialidad</label>
                    <div>@Model.Especialidad</div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Tipo de contrato</label>
                    <div>@Model.TipoContrato</div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Salario</label>
                    <div class="d-flex align-items-center gap-2">
                        <span id="salarioTexto" class="fw-semibold">••••••••</span>

                        <button type="button"
                                class="btn btn-sm btn-editar rounded-circle d-flex align-items-center justify-content-center"
                                style="width:32px; height:32px;"
                                onclick="toggleSalario(this)"
                                aria-label="Mostrar u ocultar salario"
                                aria-pressed="false">
                            <i id="iconoSalario" class="bi bi-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="col-md-6">
                    <label class="fw-semibold text-muted d-block">Nivel académico</label>
                    <div>@Model.NivelAcademico</div>
                </div>

                <div class="col-md-6">
                    <label class="fw-semibold text-muted d-block">Descripción académica</label>
                    <div>
                        @(string.IsNullOrWhiteSpace(Model.DescripcionGrado)
                                                ? "Sin descripción"
                                                : Model.DescripcionGrado)
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <h6 class="text-muted mb-4">Información de contacto</h6>

            <div class="row g-4">
                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Teléfono</label>
                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Telefono)
                                                ? "Sin teléfono"
                                                : Model.Telefono)
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Correo alterno</label>
                    <div>
                        @(string.IsNullOrWhiteSpace(Model.EmailContacto)
                                                ? "Sin correo alterno"
                                                : Model.EmailContacto)
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Dirección</label>
                    <div>
                        @(string.IsNullOrWhiteSpace(Model.Direccion)
                                                ? "Sin dirección registrada"
                                                : Model.Direccion)
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <h6 class="text-muted mb-4">Fechas del contrato</h6>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="border rounded-3 p-3 bg-light h-100">
                        <small class="text-muted d-block mb-1">Fecha de ingreso</small>
                        <div class="fw-semibold">
                            @(Model.FechaIngreso?.ToString("dd/MM/yyyy") ?? "Sin definir")
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="border rounded-3 p-3 bg-light h-100">
                        <small class="text-muted d-block mb-1">Fin de contrato</small>
                        <div class="fw-semibold">
                            @(Model.FechaFinContrato?.ToString("dd/MM/yyyy") ?? "Sin definir")
                        </div>
                    </div>
                </div>
            </div>

            <hr class="my-4" />

            <h6 class="text-muted mb-4">Información del sistema</h6>

            <div class="row g-4">
                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Fecha de creación</label>
                    <div>
                        @Model.FechaCreacion.ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Creado por</label>
                    <div>
                        @(Model.UsuarioCrea?.NombreCompleto ?? "Sin dato")
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="fw-semibold text-muted d-block">Última modificación</label>
                    <div>
                        @(Model.FechaModificacion?.ToString("dd/MM/yyyy HH:mm") ?? "Sin modificaciones")
                    </div>
                </div>
            </div>

            <div class="mt-5 d-flex justify-content-end gap-2">
                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-dorado">
                    Editar
                </a>
            </div>

        </div>
    </div>
</div>

<div id="toastCopiado" class="position-fixed bottom-0 end-0 p-3" style="z-index: 1080; display: none;">
    <div class="d-flex align-items-start gap-3 shadow rounded-4 border bg-white px-3 py-3">
        <div class="fs-4 text-success">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <div>
            <div class="fw-semibold">Correo copiado</div>
            <div class="text-muted small" id="toastCopiadoTexto"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let salarioVisible = false;
        let toastTimeout = null;

        function toggleSalario(boton) {
            const salarioTexto = document.getElementById("salarioTexto");
            const icono = document.getElementById("iconoSalario");

            if (salarioVisible) {
                salarioTexto.innerText = "••••••••";
                icono.className = "bi bi-eye";
                boton.setAttribute("aria-pressed", "false");
                salarioVisible = false;
            } else {
                salarioTexto.innerText = "@Model.Salario.ToString("C")";
                icono.className = "bi bi-eye-slash";
                boton.setAttribute("aria-pressed", "true");
                salarioVisible = true;
            }
        }

        async function copiarCorreo() {
            const correo = document.getElementById("correoUsuario").innerText.trim();

            try {
                await navigator.clipboard.writeText(correo);
                mostrarToast(`Se copió ${correo}`);
            } catch (e) {
                const input = document.createElement("input");
                input.value = correo;
                document.body.appendChild(input);
                input.select();
                document.execCommand("copy");
                document.body.removeChild(input);
                mostrarToast(`Se copió ${correo}`);
            }
        }

        function mostrarToast(mensaje) {
            const toast = document.getElementById("toastCopiado");
            const texto = document.getElementById("toastCopiadoTexto");

            texto.innerText = mensaje;
            toast.style.display = "block";
            toast.style.opacity = "1";
            toast.style.transform = "translateY(0)";

            if (toastTimeout) {
                clearTimeout(toastTimeout);
            }

            toastTimeout = setTimeout(() => {
                toast.style.opacity = "0";
                toast.style.transform = "translateY(10px)";
                setTimeout(() => {
                    toast.style.display = "none";
                }, 250);
            }, 2200);
        }
    </script>
}