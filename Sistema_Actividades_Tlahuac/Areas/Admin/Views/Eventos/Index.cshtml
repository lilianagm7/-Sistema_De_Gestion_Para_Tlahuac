@model List<Sistema_Actividades_Tlahuac.Models.ViewModels.Eventos.EventoIndexViewModel>

@{
    ViewData["Title"] = "Eventos";
}

<partial name="_Header_Index" />

<div class="container mt-4">

    <div class="card border-0 shadow-sm rounded-4">

        <div class="card-body p-4">

            <div class="table-responsive">

                <table class="table align-middle table-hover">

                    <thead class="table-light">
                        <tr>
                            <th>Evento</th>
                            <th>Espacio</th>
                            <th>Fecha y hora</th>
                            <th>Cupos</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <!-- Evento -->
                                <td style="min-width:280px;">

                                    <div class="d-flex align-items-center gap-3">

                                        <img src="@(!string.IsNullOrEmpty(item.ImagenUrl)
                                                                                                  ? Url.Content("~" + item.ImagenUrl)
                                                                                                  : Url.Content("~/imagenes/default.jpg"))"
                                         class="rounded-3 border shadow-sm"
                                         style="width:70px; height:70px; object-fit:cover;" />

                                        <div>

                                            <div class="fw-semibold fs-6">
                                                @item.Nombre
                                            </div>

                                            <div class="small text-muted">
                                                @item.CategoriaNombre
                                            </div>

                                        </div>

                                    </div>

                                </td>

                                <!-- Espacio -->
                                <td>
                                    @item.EspacioNombre
                                </td>

                                <!-- Fecha y hora -->
                                <td>

                                    <div class="fw-semibold">
                                        @item.FechaInicio.ToString("dd/MM/yyyy")
                                    </div>

                                    <div class="small text-muted">
                                        @item.FechaInicio.ToString("hh:mm tt")
                                    </div>

                                </td>

                                <!-- Cupos -->
                                <td>

                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2 rounded-pill">
                                        @item.CuposDisponibles
                                    </span>

                                </td>

                                <!-- Acciones -->
                                <td class="text-center">

                                    <div class="d-flex justify-content-center align-items-center gap-2">

                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-detalles rounded-circle d-flex align-items-center justify-content-center"
                                           style="width:34px; height:34px;">

                                            <i class="bi bi-eye"></i>

                                        </a>

                                        <partial name="_Botones_Tablas" model="item.Id" />

                                    </div>

                                </td>

                            </tr>
                                                }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>