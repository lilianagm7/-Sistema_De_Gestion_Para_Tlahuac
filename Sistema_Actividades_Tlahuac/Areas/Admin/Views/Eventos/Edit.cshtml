@model Sistema_Actividades_Tlahuac.Models.ViewModels.Eventos.EventoEditViewModel
@using Sistema_Actividades_Tlahuac.Models.Enums

@{
    ViewData["Title"] = "Editar evento";
}
<partial name="_Header_Vistas" />
<hr />
<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body">

                <form asp-action="Edit" enctype="multipart/form-data">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <!-- NOMBRE -->
                    <div class="form-group mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <!-- DESCRIPCIÓN -->
                    <div class="form-group mb-4">
                        <label asp-for="Descripcion" class="form-label"></label>
                        <textarea asp-for="Descripcion" class="form-control"></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <!-- BLOQUE: Configuración -->
                    <h6 class="mb-3 text-muted">Configuración del evento</h6>
                    <div class="row">
                        <!-- ESPACIO -->
                        <div class="col-md-4 mb-3">
                            <label asp-for="EspacioId" class="form-label"></label>
                            <select asp-for="EspacioId" asp-items="Model.Espacios" class="form-control"></select>
                            <span asp-validation-for="EspacioId" class="text-danger"></span>
                        </div>

                        <!-- CATEGORÍA -->
                        <div class="col-md-4 mb-3">
                            <label asp-for="CategoriaId" class="form-label"></label>
                            <select asp-for="CategoriaId" asp-items="Model.Categorias" class="form-control"></select>
                            <span asp-validation-for="CategoriaId" class="text-danger"></span>
                        </div>

                        <!-- CAPACIDAD -->
                        <div class="col-md-4 mb-3">
                            <label asp-for="CapacidadMaxima" class="form-label"></label>
                            <input asp-for="CapacidadMaxima" class="form-control" />
                            <span asp-validation-for="CapacidadMaxima" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <!-- ESTADO -->
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="form-label"></label>
                            <select asp-for="Estado" class="form-control"
                                    asp-items="Html.GetEnumSelectList<EstadoEvento>()">
                            </select>
                        </div>

                        <!-- ESPACIO VACÍO (balance visual) -->
                        <div class="col-md-6"></div>
                    </div>

                    <!-- BLOQUE: Fechas -->
                    <h6 class="mb-3 text-muted">Fechas del evento</h6>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaInicio" class="form-label"></label>
                            <input asp-for="FechaInicio" type="datetime-local" class="form-control" />
                            <span asp-validation-for="FechaInicio" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaFin" class="form-label"></label>
                            <input asp-for="FechaFin" type="datetime-local" class="form-control" />
                            <span asp-validation-for="FechaFin" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- BLOQUE: Imagen -->
                    <h6 class="mb-3 text-muted">Imagen del evento</h6>

                    <!-- Imagen actual -->
                    @if (!string.IsNullOrEmpty(Model.ImagenActualUrl))
                    {
                        <div class="mb-3">
                            <label class="form-label">Imagen actual</label><br />
                            <img src="@Url.Content("~" + Model.ImagenActualUrl)"
                                 class="img-thumbnail"
                                 style="max-height:200px;" />
                        </div>
                    }

                    <!-- Nueva imagen -->
                    <div class="form-group mb-3">
                        <label asp-for="Imagen" class="form-label"></label>
                        <input asp-for="Imagen" type="file" class="form-control" />
                        <span asp-validation-for="Imagen" class="text-danger"></span>
                    </div>

                    <!-- BOTONES -->
                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">
                            Cancelar
                        </a>

                        <button type="submit" class="btn btn-dorado">
                            Guardar cambios
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}