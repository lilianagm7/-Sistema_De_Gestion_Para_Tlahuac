@page
@model ChangePasswordModel

@{
    ViewData["Title"] = "Cambiar contraseña";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}


<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="mb-4 text-muted">Actualizar contraseña</h4>

                <form id="change-password-form" method="post">

                    <div asp-validation-summary="ModelOnly"
                         class="text-danger"
                         role="alert">
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.OldPassword" class="form-label"></label>
                        <input asp-for="Input.OldPassword"
                               type="password"
                               class="form-control"
                               autocomplete="current-password"
                               aria-required="true"
                               placeholder="Ingrese su contraseña actual" />

                        <span asp-validation-for="Input.OldPassword"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.NewPassword" class="form-label"></label>
                        <input asp-for="Input.NewPassword"
                               type="password"
                               class="form-control"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="Ingrese su nueva contraseña" />

                        <span asp-validation-for="Input.NewPassword"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.ConfirmPassword" class="form-label"></label>
                        <input asp-for="Input.ConfirmPassword"
                               type="password"
                               class="form-control"
                               autocomplete="new-password"
                               aria-required="true"
                               placeholder="Confirme su nueva contraseña" />

                        <span asp-validation-for="Input.ConfirmPassword"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">

                        <a asp-page="/"
                           class="btn btn-secondary">
                            Volver
                        </a>

                        <button type="submit"
                                class="btn btn-dorado">
                            Guardar cambios
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}