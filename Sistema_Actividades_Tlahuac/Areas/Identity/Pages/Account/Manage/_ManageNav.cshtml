@using Microsoft.AspNetCore.Identity
@using Sistema_Actividades_Tlahuac.Models
@inject SignInManager<ApplicationUser> SignInManager

@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<div class="card shadow-sm">
    <div class="card-body">

        <h5 class="mb-4 text-muted">Configuración de la cuenta</h5>

        <ul class="nav nav-pills flex-column gap-2">

            <!-- PERFIL -->
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.IndexNavClass(ViewContext)"
                   id="profile"
                   asp-page="./Index">
                    <i class="bi bi-person-circle me-2"></i>
                    Perfil
                </a>
            </li>

            <!-- EMAIL -->
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.EmailNavClass(ViewContext)"
                   id="email"
                   asp-page="./Email">
                    <i class="bi bi-envelope me-2"></i>
                    Correo electrónico
                </a>
            </li>

            <!-- CONTRASEÑA -->
            <li class="nav-item">
                <a class="nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)"
                   id="change-password"
                   asp-page="./ChangePassword">
                    <i class="bi bi-shield-lock me-2"></i>
                    Cambiar contraseña
                </a>
            </li>

            <!-- LOGINS EXTERNOS -->
            @if (hasExternalLogins)
            {
                <li id="external-logins" class="nav-item">
                    <a id="external-login"
                       class="nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)"
                       asp-page="./ExternalLogins">
                        <i class="bi bi-box-arrow-in-right me-2"></i>
                        Inicios de sesión externos
                    </a>
                </li>
            }

        </ul>

    </div>
</div>