@page
@model EmailModel



<partial name="_StatusMessage" for="StatusMessage" />

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="mb-4 text-muted">Administrar correo electrónico</h4>

                <form id="email-form" method="post">

                    <div asp-validation-summary="All"
                         class="text-danger"
                         role="alert">
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Email" class="form-label"></label>

                        @if (Model.IsEmailConfirmed)
                        {
                            <div class="input-group">
                                <input asp-for="Email"
                                       class="form-control"
                                       placeholder="Correo actual"
                                       disabled />

                                <span class="input-group-text text-success fw-bold">
                                    ✓
                                </span>
                            </div>
                        }
                        else
                        {
                            <input asp-for="Email"
                                   class="form-control mb-2"
                                   placeholder="Correo actual"
                                   disabled />

                            <button id="email-verification"
                                    type="submit"
                                    asp-page-handler="SendVerificationEmail"
                                    class="btn btn-outline-primary btn-sm">
                                Enviar verificación de correo
                            </button>
                        }
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Input.NewEmail" class="form-label"></label>
                        <input asp-for="Input.NewEmail"
                               class="form-control"
                               autocomplete="email"
                               aria-required="true"
                               placeholder="Ingrese su nuevo correo electrónico" />

                        <span asp-validation-for="Input.NewEmail"
                              class="text-danger">
                        </span>
                    </div>

                    <div class="mt-4 d-flex justify-content-end gap-2">
                        <a asp-page="/"
                           class="btn btn-secondary">
                            Volver
                        </a>

                        <button id="change-email-button"
                                type="submit"
                                asp-page-handler="ChangeEmail"
                                class="btn btn-dorado">
                            Guardar cambios
                        </button>

                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}