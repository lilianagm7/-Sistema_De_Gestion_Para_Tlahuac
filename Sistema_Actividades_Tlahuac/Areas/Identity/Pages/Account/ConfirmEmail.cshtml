@page
@model ConfirmEmailModel

@{
    ViewData["Title"] = "Confirmación de correo electrónico";
}

<partial name="_Header_Vistas" />

<hr />

<div class="row justify-content-center">
    <div class="col-lg-7">

        <div class="card shadow-sm">
            <div class="card-body text-center">

                <div class="mb-4">
                    <i class="bi bi-check-circle-fill text-success"
                       style="font-size: 4rem;">
                    </i>
                </div>

                <h3 class="mb-3">
                    Correo confirmado correctamente
                </h3>

                <p class="text-muted mb-4">
                    La confirmación de tu correo electrónico fue exitosa.
                    Ahora puedes iniciar sesión y continuar usando la plataforma.
                </p>

                <partial name="_StatusMessage" model="Model.StatusMessage" />

                <div class="mt-4">
                    <a asp-page="/Account/Login"
                       class="btn btn-dorado px-4">
                        Ir al inicio de sesión
                    </a>
                </div>

            </div>
        </div>

    </div>
</div>