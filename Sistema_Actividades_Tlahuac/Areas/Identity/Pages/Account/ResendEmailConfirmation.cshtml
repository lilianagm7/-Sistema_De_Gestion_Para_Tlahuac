@page
@model Sistema_Actividades_Tlahuac.Areas.Identity.Pages.Account.ResendEmailConfirmationModel
@{
    ViewData["Title"] = "Reenviar confirmación";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-3">
                <div class="card-body p-4">

                    <h3 class="text-center mb-3">Reenviar confirmación</h3>

                    <p class="text-muted text-center">
                        Ingresa tu correo electrónico para recibir nuevamente el enlace de confirmación.
                    </p>

                    <form method="post">
                        <div class="form-group mb-3">
                            <label asp-for="Email" class="form-label">Correo electrónico</label>
                            <input asp-for="Email" class="form-control" placeholder="ejemplo@correo.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            Reenviar correo
                        </button>
                    </form>
                    @if (TempData["Mensaje"] != null)
                    {
                        <div class="alert alert-info text-center">
                            @TempData["Mensaje"]
                        </div>
                    }
                    <hr />

                    <div class="text-center">
                        <a asp-page="/Account/Login">Volver al inicio de sesión</a>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
